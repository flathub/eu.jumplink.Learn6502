{
    "id": "eu.jumplink.Learn6502",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.node24",
        "org.freedesktop.Sdk.Extension.typescript"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/node24/bin:/usr/lib/sdk/typescript/bin:/app/bin"
    },
    "command": "eu.jumplink.Learn6502",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland"
    ],
    "modules": [
        {
            "name": "Learn6502",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/JumpLink/Learn6502.git",
                    "tag": "v0.6.5",
                    "commit": "1f355ede425cf75aa848198ca1c141092a110aa4",
                    "disable-submodules": true,
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^v(\\d+\\.\\d+\\.\\d+)$",
                        "version-scheme": "semantic"
                    }
                }
            ]
        }
    ]
}
